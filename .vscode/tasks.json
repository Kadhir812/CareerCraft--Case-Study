{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Spring Boot",
      "type": "shell",
      "command": ".\\mvnw.cmd",
      "args": ["spring-boot:run"],
      "options": {
        "cwd": "${workspaceFolder}/backend_careercrafter",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoLogo", "-NoProfile", "-Command"]
        }
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: Vite",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend_careercrafter",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoLogo", "-NoProfile", "-Command"]
        }
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Full Stack",
      "dependsOn": [
        "Backend: Spring Boot",
        "Frontend: Vite"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}